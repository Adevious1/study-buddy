# Database
DATABASE_URL=postgres://studybuddy:studybuddy@postgres:5432/studybuddy

# Web → server
# VITE_API_TARGET: where Vite's dev proxy forwards "/api" requests (server-side).
VITE_API_TARGET=http://server:3001
# VITE_API_BASE: base URL the browser client prepends to API paths. Defaults to
# "/api" (which goes through the Vite proxy above). Set to an absolute URL only
# when the client must reach the API directly without the proxy.
# VITE_API_BASE=/api
VITE_CURRENT_CHILD_ID=00000000-0000-0000-0000-000000000001

# Gemini Live API (SP3 voice tutor) — server-side only, never exposed to the web app.
GEMINI_API_KEY=your-gemini-api-key
