# Copy this file to .env and fill in real values.
# Never commit .env — only .env.example belongs in git.

# Database
DATABASE_URL=postgres://studybuddy:studybuddy@postgres:5432/studybuddy

# Web → server
# VITE_API_TARGET: where Vite's dev proxy forwards "/api" requests (server-side).
VITE_API_TARGET=http://server:3001

# Gemini Live API (SP3 voice tutor) — server-side only, never exposed to the web app.
GEMINI_API_KEY=your-gemini-api-key

# Auth (SP4) — better-auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret-in-prod
# The URL the browser uses to reach auth (through the Vite proxy in dev).
BETTER_AUTH_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Billing (SP5) — Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-price-id
BILLING_TRIAL_DAYS=14
PUBLIC_APP_URL=http://localhost:5173

# Observability (SP10) — Sentry error tracking + ops metrics. ALL OPTIONAL:
# unset means disabled (dev/CI need none of these).
SENTRY_DSN=
VITE_SENTRY_DSN=
# Bearer token for GET /api/ops/metrics (unset → endpoint 404s)
OPS_METRICS_TOKEN=
# Build-time only (future prod web build): enables source-map upload to Sentry
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
